DirectoryIndex index.php index.html
Options -Indexes

# Allow direct access to the authentication handler
RewriteEngine On
RewriteBase /primefacilityservicesgroup/hospitality/

# Don't rewrite actual files or directories
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route all requests to index.php for authentication handling
RewriteRule ^(.*)$ index.php [QSA,L]
